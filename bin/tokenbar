quiet=false
animate=true
force_animation=false

case "${1:-}" in
  -h|--help|help)
    usage
    exit 0
    ;;
  --install|install)
    install_tokenbar
    exit 0
    ;;
  --path|path)
    find_app
    exit $?
    ;;
  --quiet|-q)
    quiet=true
    animate=false
    ;;
  --no-animation|--plain)
    animate=false
    ;;
  --movie)
    force_animation=true
    ;;
  "")
    ;;
  *)
    echo "Unknown option: $1" >&2
    usage >&2
    exit 2
    ;;
esac

if app_path="$(find_app)"; then
  open "$app_path"
  if [[ "$quiet" == true ]]; then
    exit 0
  elif [[ "$animate" == true && "$force_animation" == true ]]; then
    animated_open_message "$app_path"
  elif [[ "$animate" == true ]] && supports_animation; then
    animated_open_message "$app_path"
  else
    plain_open_message "$app_path"
  fi
  exit 0
fi

cat >&2 <<EOF
TokenBar is not installed yet.

Install it with:
  curl -fsSL $install_url | bash

Or download it manually:
  $download_url
EOF
exit 1
