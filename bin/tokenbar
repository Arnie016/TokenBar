#!/usr/bin/env bash
set -euo pipefail

APP_CANDIDATES=(
  "${TOKENBAR_APP:-}"
  "$HOME/Applications/TokenBar.app"
  "$HOME/Applications/CodexLimitBar.app"
  "/Applications/TokenBar.app"
  "/Applications/CodexLimitBar.app"
)

download_url="https://github.com/Arnie016/codex-goated-skills/releases/download/v0.1.0/CodexLimitBar-macOS-arm64-2026-05-20.zip"
install_url="https://raw.githubusercontent.com/Arnie016/TokenBar/main/install.sh"

usage() {
  cat <<'USAGE'
TokenBar terminal launcher

Usage:
  tokenbar              Open TokenBar
  tokenbar --install    Install TokenBar into ~/Applications and ~/.local/bin
  tokenbar --path       Print the app path if found
  tokenbar --quiet      Open TokenBar without terminal output
  tokenbar --no-animation
                        Open TokenBar with one plain status line
  tokenbar --movie      Force the terminal mini-movie
  tokenbar --no-agent   Open TokenBar and return to the shell
  tokenbar --help       Show this help

USAGE
}

find_app() {
  local candidate
  for candidate in "${APP_CANDIDATES[@]}"; do
    if [[ -n "$candidate" && -d "$candidate" ]]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done
  return 1
}

install_tokenbar() {
  /bin/bash -c "$(curl -fsSL "$install_url")"
}

supports_animation() {
  [[ -t 1 && "${TERM:-dumb}" != "dumb" && -z "${NO_COLOR:-}" ]]
}

plain_open_message() {
  printf 'Opened TokenBar: %s\n' "$1"
}

supports_agent_interface() {
  [[ -t 0 && -t 1 ]]
}

answer_agent_prompt() {
  local app_path="$1"
  local input="$2"
  local lower
  lower="$(printf '%s' "$input" | tr '[:upper:]' '[:lower:]')"

  case "$lower" in
    *help*|*commands*|*\?*)
      cat <<'EOF'
Try:
  usage        explain what TokenBar can read locally
  cost         explain dollar estimates
  energy       explain tokens / watt / dollar
  agents       provider connector status
  bugs         useful diagnostics
  open         reopen the menu bar app
  quit         leave this prompt
EOF
      ;;
    *open*|*launch*)
      open "$app_path"
      printf 'Opened TokenBar again: %s\n' "$app_path"
      ;;
    *usage*|*token*|*quota*|*limit*)
      cat <<'EOF'
TokenBar currently reads OpenAI Codex usage from local session logs and combines that with the visible 5-hour and weekly quota windows. The macOS app is the source of truth for the live graph: token history, dotted forecast, peak day, weekly pressure, and projected local cost.
EOF
      ;;
    *aggregate*|*summary*|*insight*|*comment*|*explain*)
      cat <<'EOF'
TokenBar separates real aggregates from estimates:
  Real local aggregates: Codex session tokens by day, local model names when present, session count, peak day, active days.
  Rate-limit aggregates: 5-hour and weekly quota state when Codex exposes it locally.
  Estimates: cost forecast and energy framing.
  Not connected yet: Claude, Gemini, Cursor, Antigravity usage APIs.

The useful commentary layer should say why a number matters: "peak day drove the week", "weekly pressure is the constraint", "forecast is based on recent pace", or "provider connector missing". It should not invent provider totals.
EOF
      ;;
    *cost*|*dollar*|*spend*|*billing*)
      cat <<'EOF'
Dollar numbers are local estimates: tokens multiplied by the configured cost-per-million value. They are useful for trend and burn-rate awareness, but official billing, credits, org attribution, and purchased reserves still belong to the provider dashboard.
EOF
      ;;
    *energy*|*watt*|*joule*|*electron*|*power*)
      cat <<'EOF'
The useful frontier metric is tokens / watt / dollar: how much useful reasoning you get for power and money. TokenBar does not yet sample real Mac power draw. A future energy connector should combine local token logs with battery/powermetrics samples to estimate joules per session and tokens per watt-hour.
EOF
      ;;
    *agent*|*provider*|*chatgpt*|*openai*|*codex*|*claude*|*anthropic*|*gemini*|*cursor*|*antigravity*)
      cat <<'EOF'
Provider status:
  OpenAI Codex: live local log reader.
  ChatGPT/Codex account limits: visible through Codex rate-limit data when available.
  Claude, Gemini, Cursor, Antigravity: future connector targets.

Browser sign-in is not enough. Real connectors need explicit usage APIs, local exports, or safe user-provided tokens stored outside the repo.
EOF
      ;;
    *bug*|*debug*|*fix*|*diagnostic*)
      cat <<EOF
Diagnostics:
  App path: $app_path
  Launcher: $(command -v tokenbar 2>/dev/null || printf 'not on PATH')

Useful commands:
  tokenbar --path
  tokenbar --no-animation --no-agent
  tokenbar --install
EOF
      ;;
    *install*|*download*|*update*)
      cat <<EOF
Install or refresh TokenBar with:
  curl -fsSL $install_url | bash

Current download:
  $download_url
EOF
      ;;
    *quit*|*exit*|*bye*)
      return 10
      ;;
    "")
      ;;
    *)
      cat <<'EOF'
I can answer local TokenBar questions about usage, cost, energy, providers, and diagnostics. I am not a cloud-auth connector yet; I do not read browser cookies or provider secrets. Type `help` for examples.
EOF
      ;;
  esac
}

agent_interface() {
  local app_path="$1"
  local cyan=$'\033[36m'
  local green=$'\033[32m'
  local dim=$'\033[2m'
  local reset=$'\033[0m'
  local input

  printf '\n%sTokenBar agent%s  %sask about usage, cost, energy, agents, bugs; type quit%s\n' "$green" "$reset" "$dim" "$reset"
  while true; do
    printf '%sTokenBar ›%s ' "$cyan" "$reset"
    if ! IFS= read -r input; then
      printf '\n'
      break
    fi
    answer_agent_prompt "$app_path" "$input"
    local status=$?
    if [[ "$status" == "10" ]]; then
      break
    fi
  done
}

animated_open_message() {
  local app_path="$1"
  local cyan=$'\033[36m'
  local blue=$'\033[34m'
  local amber=$'\033[33m'
  local green=$'\033[32m'
  local violet=$'\033[35m'
  local red=$'\033[31m'
  local dim=$'\033[2m'
  local reset=$'\033[0m'
  local clear_down=$'\033[J'
  local clear_screen=$'\033[H\033[J'
  local frame total_lines=12
  local captions=(
    "local-first monitor warming up"
    "electrons enter the meter"
    "joules become compute"
    "compute becomes tokens"
    "tokens hit the quota gate"
    "aggregating local Codex logs"
    "separating facts from estimates"
    "forecast line prepared"
    "cost and energy commentary ready"
    "opening native menu-bar surface"
  )

  draw_movie_frame() {
    local index="$1"
    local caption="${captions[$index]}"
    local spark_pad electron_wave token_wave gate_bar graph_line sprite eyes mouth
    local spark_count=$((index % 5 + 1))

    printf -v spark_pad '%*s' "$((index + 2))" ''
    electron_wave="${spark_pad}e-  e-  e-  --->"
    token_wave="$(printf '%*s' "$((16 - index))" '')"
    token_wave="${token_wave}[tok] ✦ [tok] ✦"
    graph_line="$(printf '%*s' "$((index + 4))" '')"
    graph_line="${graph_line}╭─╮__╭─╮····╮"

    case $((index % 4)) in
      0) eyes="o  o"; mouth="▵" ;;
      1) eyes="^  ^"; mouth="-" ;;
      2) eyes=">  <"; mouth="!" ;;
      *) eyes="•  •"; mouth="v" ;;
    esac

    if (( index < 3 )); then
      gate_bar="${dim}░░░░░░░░░░${reset}"
    elif (( index < 6 )); then
      gate_bar="${amber}████░░░░░░${reset}"
    else
      gate_bar="${green}███████░░░${reset}"
    fi

    sprite="${cyan}.--.__.--.${reset}"

    cat <<EOF
${violet}╭─ TokenBar: terminal usage interface ─────────────────────────────────────╮${reset}
${violet}│${reset}  ${dim}${caption}${reset}
${violet}│${reset}
${violet}│${reset}  ${dim}${electron_wave}${reset}      ${amber}J per dollar${reset}  →  ${blue}W per dollar${reset}  →  ${green}tok/W per dollar${reset}
${violet}│${reset}                         ${sprite}        ${dim}agent character${reset}
${violet}│${reset}                        ${cyan}(  ${eyes}  )${reset}      ${token_wave}
${violet}│${reset}                         ${cyan}(   ${mouth}   )${reset}      quota gate ${gate_bar}
${violet}│${reset}                          ${cyan}'-.__.-'${reset}
${violet}│${reset}    facts: ${green}local Codex logs${reset}   estimates: ${amber}cost + energy${reset}   missing: ${red}external connectors${reset}
${violet}│${reset}    ${graph_line}   ${dim}solid history line, dotted projection${reset}
${violet}│${reset}
${violet}╰────────────────────────────────────────────────────────────────────────────╯${reset}
EOF
  }

  trap "printf '\033[?25h'; trap - INT TERM EXIT" INT TERM EXIT
  printf '\033[?25l'
  for frame in "${!captions[@]}"; do
    if [[ "$frame" != "0" ]]; then
      printf '\033[%sA' "$total_lines"
    fi
    printf '%s' "$clear_screen"
    draw_movie_frame "$frame"
    sleep 0.18
  done
  printf '%s✓ TokenBar is live%s  %sfacts aggregated, estimates labeled%s\n' "$green" "$reset" "$amber" "$reset"
  printf '\033[?25h'
  trap - INT TERM EXIT
}

quiet=false
animate=true
force_animation=false
agent=true

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help|help)
      usage
      exit 0
      ;;
    --install|install)
      install_tokenbar
      exit 0
      ;;
    --path|path)
      find_app
      exit $?
      ;;
    --quiet|-q)
      quiet=true
      animate=false
      agent=false
      ;;
    --no-animation|--plain)
      animate=false
      ;;
    --movie)
      force_animation=true
      ;;
    --no-agent)
      agent=false
      ;;
    *)
      echo "Unknown option: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
  shift
done

if app_path="$(find_app)"; then
  open "$app_path"
  if [[ "$quiet" == true ]]; then
    exit 0
  elif [[ "$animate" == true && "$force_animation" == true ]]; then
    animated_open_message "$app_path"
  elif [[ "$animate" == true ]] && supports_animation; then
    animated_open_message "$app_path"
  else
    plain_open_message "$app_path"
  fi
  if [[ "$agent" == true ]] && supports_agent_interface; then
    agent_interface "$app_path"
  fi
  exit 0
fi

cat >&2 <<EOF
TokenBar is not installed yet.

Install it with:
  curl -fsSL $install_url | bash

Or download it manually:
  $download_url
EOF
exit 1
