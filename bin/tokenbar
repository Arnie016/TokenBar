${violet}в”‚${reset}           ${cyan}'-.__.-'${reset}      ${green}[tok]${reset}  ${red}в–Њ${reset}       ${dim}limits should be seen early${reset}     ${violet}в”‚${reset}
${violet}в”‚${reset}             ${cyan}/в–Њв–Њ\\${reset}           ${green}[tok]${reset} ${red}в–Њ${reset}                                   ${violet}в”‚${reset}
${violet}в”‚${reset}                                                                            ${violet}в”‚${reset}
${violet}в”‚${reset}       ${amber}metric:${reset} tokens per watt per dollar                              ${violet}в”‚${reset}
${violet}в•°в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв•Ї${reset}
EOF
        ;;
      5)
        cat <<EOF
${violet}в•­в”Ђ TokenBar mini movie в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв•®${reset}
${violet}в”‚${reset}  ${dim}scene 5/6${reset}  radar locks onto usage                                      ${violet}в”‚${reset}
${violet}в”‚${reset}                                                                            ${violet}в”‚${reset}
${violet}в”‚${reset}                       ${blue}в•­в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв•®${reset}                             ${violet}в”‚${reset}
${violet}в”‚${reset}      ${cyan}.--.__.--.${reset}   ${blue}в”‚${reset}  ${green}226M today${reset}  ${blue}в”‚${reset}     ${dim}history line + forecast${reset}     ${violet}в”‚${reset}
${violet}в”‚${reset}     ${cyan}(  o  o  )${reset}  ${blue}в”‚${reset}  ${amber}97% weekly${reset}  ${blue}в”‚${reset}                             ${violet}в”‚${reset}
${violet}в”‚${reset}      ${cyan}'-.__.-'${reset}   ${blue}в”‚${reset}  ${violet}cost burn${reset}   ${blue}в”‚${reset}                             ${violet}в”‚${reset}
${violet}в”‚${reset}          ${cyan}/в–Њ\\${reset}     ${blue}в•°в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв•Ї${reset}                             ${violet}в”‚${reset}
${violet}в”‚${reset}                                                                            ${violet}в”‚${reset}
${violet}в•°в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв•Ї${reset}
