    esac
  }

  trap "printf '\033[?25h'; trap - INT TERM EXIT" INT TERM EXIT
  printf '\033[?25l'
  for frame in 1 2 3 4 5 6; do
    if [[ "$frame" != "1" ]]; then
      printf '\033[%sA' "$total_lines"
    fi
    printf '%s' "$clear_down"
    draw_movie_frame "$frame"
    sleep 0.42
  done
  printf '%sвњ“ TokenBar is live%s  %stokens / watt / dollar%s\n' "$green" "$reset" "$amber" "$reset"
  printf '\033[?25h'
  trap - INT TERM EXIT
