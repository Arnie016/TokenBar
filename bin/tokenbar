#!/usr/bin/env bash
set -euo pipefail

APP_CANDIDATES=(
  "${TOKENBAR_APP:-}"
  "$HOME/Applications/TokenBar.app"
  "$HOME/Applications/CodexLimitBar.app"
  "/Applications/TokenBar.app"
  "/Applications/CodexLimitBar.app"
)

download_url="https://github.com/Arnie016/codex-goated-skills/releases/download/v0.1.0/CodexLimitBar-macOS-arm64-2026-05-20.zip"
install_url="https://raw.githubusercontent.com/Arnie016/TokenBar/main/install.sh"

usage() {
  cat <<'USAGE'
TokenBar terminal launcher

Usage:
  tokenbar              Open TokenBar
  tokenbar --install    Install TokenBar into ~/Applications and ~/.local/bin
  tokenbar --path       Print the app path if found
  tokenbar --quiet      Open TokenBar without terminal output
  tokenbar --no-animation
                        Open TokenBar with one plain status line
  tokenbar --movie      Force the terminal mini-movie
  tokenbar --no-agent   Open TokenBar and return to the shell
  tokenbar --help       Show this help

USAGE
}

find_app() {
  local candidate
  for candidate in "${APP_CANDIDATES[@]}"; do
    if [[ -n "$candidate" && -d "$candidate" ]]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done
  return 1
}

install_tokenbar() {
  /bin/bash -c "$(curl -fsSL "$install_url")"
}

supports_animation() {
  [[ -t 1 && "${TERM:-dumb}" != "dumb" && -z "${NO_COLOR:-}" ]]
}

plain_open_message() {
  printf 'Opened TokenBar: %s\n' "$1"
}

supports_agent_interface() {
  [[ -t 0 && -t 1 ]]
}

answer_agent_prompt() {
  local app_path="$1"
  local input="$2"
  local lower
  lower="$(printf '%s' "$input" | tr '[:upper:]' '[:lower:]')"

  case "$lower" in
    *help*|*commands*|*\?*)
      cat <<'EOF'
Try:
  usage        explain what TokenBar can read locally
  cost         explain dollar estimates
  energy       explain tokens / watt / dollar
  agents       provider connector status
  bugs         useful diagnostics
  open         reopen the menu bar app
  quit         leave this prompt
EOF
      ;;
    *open*|*launch*)
      open "$app_path"
      printf 'Opened TokenBar again: %s\n' "$app_path"
      ;;
    *usage*|*token*|*quota*|*limit*)
      cat <<'EOF'
TokenBar currently reads OpenAI Codex usage from local session logs and combines that with the visible 5-hour and weekly quota windows. The macOS app is the source of truth for the live graph: token history, dotted forecast, peak day, weekly pressure, and projected local cost.
EOF
      ;;
    *cost*|*dollar*|*spend*|*billing*)
      cat <<'EOF'
Dollar numbers are local estimates: tokens multiplied by the configured cost-per-million value. They are useful for trend and burn-rate awareness, but official billing, credits, org attribution, and purchased reserves still belong to the provider dashboard.
EOF
      ;;
    *energy*|*watt*|*joule*|*electron*|*power*)
      cat <<'EOF'
The useful frontier metric is tokens / watt / dollar: how much useful reasoning you get for power and money. TokenBar does not yet sample real Mac power draw. A future energy connector should combine local token logs with battery/powermetrics samples to estimate joules per session and tokens per watt-hour.
EOF
      ;;
    *agent*|*provider*|*chatgpt*|*openai*|*codex*|*claude*|*anthropic*|*gemini*|*cursor*|*antigravity*)
      cat <<'EOF'
Provider status:
  OpenAI Codex: live local log reader.
  ChatGPT/Codex account limits: visible through Codex rate-limit data when available.
  Claude, Gemini, Cursor, Antigravity: future connector targets.

Browser sign-in is not enough. Real connectors need explicit usage APIs, local exports, or safe user-provided tokens stored outside the repo.
EOF
      ;;
    *bug*|*debug*|*fix*|*diagnostic*)
      cat <<EOF
Diagnostics:
  App path: $app_path
  Launcher: $(command -v tokenbar 2>/dev/null || printf 'not on PATH')

Useful commands:
  tokenbar --path
  tokenbar --no-animation --no-agent
  tokenbar --install
EOF
      ;;
    *install*|*download*|*update*)
      cat <<EOF
Install or refresh TokenBar with:
  curl -fsSL $install_url | bash

Current download:
  $download_url
EOF
      ;;
    *quit*|*exit*|*bye*)
      return 10
      ;;
    "")
      ;;
    *)
      cat <<'EOF'
I can answer local TokenBar questions about usage, cost, energy, providers, and diagnostics. I am not a cloud-auth connector yet; I do not read browser cookies or provider secrets. Type `help` for examples.
EOF
      ;;
  esac
}

agent_interface() {
  local app_path="$1"
  local cyan=$'\033[36m'
  local green=$'\033[32m'
  local dim=$'\033[2m'
  local reset=$'\033[0m'
  local input

  printf '\n%sTokenBar agent%s  %sask about usage, cost, energy, agents, bugs; type quit%s\n' "$green" "$reset" "$dim" "$reset"
  while true; do
    printf '%sTokenBar ›%s ' "$cyan" "$reset"
    if ! IFS= read -r input; then
      printf '\n'
      break
    fi
    answer_agent_prompt "$app_path" "$input"
    local status=$?
    if [[ "$status" == "10" ]]; then
      break
    fi
  done
}

animated_open_message() {
  local app_path="$1"
  local cyan=$'\033[36m'
  local blue=$'\033[34m'
  local amber=$'\033[33m'
  local green=$'\033[32m'
  local violet=$'\033[35m'
  local red=$'\033[31m'
  local dim=$'\033[2m'
  local reset=$'\033[0m'
  local clear_down=$'\033[J'
  local frame
  local total_lines=10

  draw_movie_frame() {
    local step="$1"
    case "$step" in
      1)
        cat <<EOF
${violet}╭─ TokenBar mini movie ─────────────────────────────────────────────────────╮${reset}
${violet}│${reset}  ${dim}scene 1/6${reset}  electrons enter the meter                                      ${violet}│${reset}
${violet}│${reset}                                                                            ${violet}│${reset}
${violet}│${reset}      e-       e-        e-                ${dim}raw work current${reset}              ${violet}│${reset}
${violet}│${reset}        \\       |        /                                                   ${violet}│${reset}
${violet}│${reset}         \\      |       /        ${amber}Joules / dollar${reset}                      ${violet}│${reset}
${violet}│${reset}          \\     |      /                                                   ${violet}│${reset}
${violet}│${reset}           [  watt gate  ]        ${dim}power becomes compute${reset}                  ${violet}│${reset}
${violet}│${reset}                                                                            ${violet}│${reset}
${violet}╰────────────────────────────────────────────────────────────────────────────╯${reset}
EOF
        ;;
      2)
        cat <<EOF
${violet}╭─ TokenBar mini movie ─────────────────────────────────────────────────────╮${reset}
${violet}│${reset}  ${dim}scene 2/6${reset}  the cloud sprite wakes up                                    ${violet}│${reset}
${violet}│${reset}                                                                            ${violet}│${reset}
${violet}│${reset}                         ${cyan}.--.__.--.${reset}                                      ${violet}│${reset}
${violet}│${reset}      e-  e-  e-  --->   ${cyan}(  o  o  )${reset}      ${dim}agent appetite rising${reset}       ${violet}│${reset}
${violet}│${reset}                         ${cyan}(   ▵   )${reset}                                      ${violet}│${reset}
${violet}│${reset}                          ${cyan}'-.__.-'${reset}       ${amber}tokens / watt / dollar${reset}     ${violet}│${reset}
${violet}│${reset}                            ${cyan}/▌▌\\${reset}                                        ${violet}│${reset}
${violet}│${reset}                                                                            ${violet}│${reset}
${violet}╰────────────────────────────────────────────────────────────────────────────╯${reset}
EOF
        ;;
      3)
        cat <<EOF
${violet}╭─ TokenBar mini movie ─────────────────────────────────────────────────────╮${reset}
${violet}│${reset}  ${dim}scene 3/6${reset}  electrons crystallize into tokens                           ${violet}│${reset}
${violet}│${reset}                                                                            ${violet}│${reset}
${violet}│${reset}      ${dim}e- e-${reset}  ->  ${amber}J${reset}  ->  ${blue}W${reset}  ->  ${green}[tok]${reset}  ${green}[tok]${reset}  ${green}[tok]${reset}                  ${violet}│${reset}
${violet}│${reset}                                                                            ${violet}│${reset}
${violet}│${reset}                         ${cyan}.--.__.--.${reset}                                      ${violet}│${reset}
${violet}│${reset}                        ${cyan}(  ^  ^  )${reset}  ${green}✦${reset} ${green}✦${reset} ${green}✦${reset}                         ${violet}│${reset}
${violet}│${reset}                         ${cyan}'-.__.-'${reset}    ${dim}context turns visible${reset}             ${violet}│${reset}
${violet}│${reset}                                                                            ${violet}│${reset}
${violet}╰────────────────────────────────────────────────────────────────────────────╯${reset}
EOF
        ;;
      4)
        cat <<EOF
${violet}╭─ TokenBar mini movie ─────────────────────────────────────────────────────╮${reset}
${violet}│${reset}  ${dim}scene 4/6${reset}  quota gate battle                                            ${violet}│${reset}
${violet}│${reset}                                                                            ${violet}│${reset}
${violet}│${reset}           ${cyan}.--.__.--.${reset}              ${red}██████████${reset} 100% gate              ${violet}│${reset}
${violet}│${reset}          ${cyan}(  >  <  )${reset}  ${green}[tok]${reset} ${green}[tok]${reset}  ${red}▌${reset}                           ${violet}│${reset}
${violet}│${reset}           ${cyan}'-.__.-'${reset}      ${green}[tok]${reset}  ${red}▌${reset}       ${dim}limits should be seen early${reset}     ${violet}│${reset}
${violet}│${reset}             ${cyan}/▌▌\\${reset}           ${green}[tok]${reset} ${red}▌${reset}                                   ${violet}│${reset}
${violet}│${reset}                                                                            ${violet}│${reset}
${violet}│${reset}       ${amber}metric:${reset} tokens per watt per dollar                              ${violet}│${reset}
${violet}╰────────────────────────────────────────────────────────────────────────────╯${reset}
EOF
        ;;
      5)
        cat <<EOF
${violet}╭─ TokenBar mini movie ─────────────────────────────────────────────────────╮${reset}
${violet}│${reset}  ${dim}scene 5/6${reset}  radar locks onto usage                                      ${violet}│${reset}
${violet}│${reset}                                                                            ${violet}│${reset}
${violet}│${reset}                       ${blue}╭──────────────╮${reset}                             ${violet}│${reset}
${violet}│${reset}      ${cyan}.--.__.--.${reset}   ${blue}│${reset}  ${green}226M today${reset}  ${blue}│${reset}     ${dim}history line + forecast${reset}     ${violet}│${reset}
${violet}│${reset}     ${cyan}(  o  o  )${reset}  ${blue}│${reset}  ${amber}97% weekly${reset}  ${blue}│${reset}                             ${violet}│${reset}
${violet}│${reset}      ${cyan}'-.__.-'${reset}   ${blue}│${reset}  ${violet}cost burn${reset}   ${blue}│${reset}                             ${violet}│${reset}
${violet}│${reset}          ${cyan}/▌\\${reset}     ${blue}╰──────────────╯${reset}                             ${violet}│${reset}
${violet}│${reset}                                                                            ${violet}│${reset}
${violet}╰────────────────────────────────────────────────────────────────────────────╯${reset}
EOF
        ;;
      *)
        cat <<EOF
${violet}╭─ TokenBar mini movie ─────────────────────────────────────────────────────╮${reset}
${violet}│${reset}  ${dim}scene 6/6${reset}  menu-bar launch                                             ${violet}│${reset}
${violet}│${reset}                                                                            ${violet}│${reset}
${violet}│${reset}             ${green}✦ [ TokenBar ] ✦${reset}                                        ${violet}│${reset}
${violet}│${reset}                                                                            ${violet}│${reset}
${violet}│${reset}        ${green}✓ live${reset}    ${cyan}tokens${reset}    ${amber}watts${reset}    ${blue}dollars${reset}    ${violet}limits${reset}                 ${violet}│${reset}
${violet}│${reset}                                                                            ${violet}│${reset}
${violet}│${reset}        ${dim}app found locally; opening native menu-bar surface${reset}              ${violet}│${reset}
${violet}│${reset}                                                                            ${violet}│${reset}
${violet}╰────────────────────────────────────────────────────────────────────────────╯${reset}
EOF
        ;;
    esac
  }

  trap "printf '\033[?25h'; trap - INT TERM EXIT" INT TERM EXIT
  printf '\033[?25l'
  for frame in 1 2 3 4 5 6; do
    if [[ "$frame" != "1" ]]; then
      printf '\033[%sA' "$total_lines"
    fi
    printf '%s' "$clear_down"
    draw_movie_frame "$frame"
    sleep 0.42
  done
  printf '%s✓ TokenBar is live%s  %stokens / watt / dollar%s\n' "$green" "$reset" "$amber" "$reset"
  printf '\033[?25h'
  trap - INT TERM EXIT
}

quiet=false
animate=true
force_animation=false
agent=true

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help|help)
      usage
      exit 0
      ;;
    --install|install)
      install_tokenbar
      exit 0
      ;;
    --path|path)
      find_app
      exit $?
      ;;
    --quiet|-q)
      quiet=true
      animate=false
      agent=false
      ;;
    --no-animation|--plain)
      animate=false
      ;;
    --movie)
      force_animation=true
      ;;
    --no-agent)
      agent=false
      ;;
    *)
      echo "Unknown option: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
  shift
done

if app_path="$(find_app)"; then
  open "$app_path"
  if [[ "$quiet" == true ]]; then
    exit 0
  elif [[ "$animate" == true && "$force_animation" == true ]]; then
    animated_open_message "$app_path"
  elif [[ "$animate" == true ]] && supports_animation; then
    animated_open_message "$app_path"
  else
    plain_open_message "$app_path"
  fi
  if [[ "$agent" == true ]] && supports_agent_interface; then
    agent_interface "$app_path"
  fi
  exit 0
fi

cat >&2 <<EOF
TokenBar is not installed yet.

Install it with:
  curl -fsSL $install_url | bash

Or download it manually:
  $download_url
EOF
exit 1
