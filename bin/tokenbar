#!/usr/bin/env bash
set -euo pipefail

APP_CANDIDATES=(
  "${TOKENBAR_APP:-}"
  "$HOME/Applications/TokenBar.app"
  "$HOME/Applications/CodexLimitBar.app"
  "/Applications/TokenBar.app"
  "/Applications/CodexLimitBar.app"
)

download_url="https://github.com/Arnie016/codex-goated-skills/releases/download/v0.1.0/CodexLimitBar-macOS-arm64-2026-05-20.zip"
install_url="https://raw.githubusercontent.com/Arnie016/TokenBar/main/install.sh"

usage() {
  cat <<'USAGE'
TokenBar terminal launcher

Usage:
  tokenbar              Open TokenBar
  tokenbar --install    Install TokenBar into ~/Applications and ~/.local/bin
  tokenbar --path       Print the app path if found
  tokenbar --quiet      Open TokenBar without terminal output
  tokenbar --no-animation
                        Open TokenBar with one plain status line
  tokenbar --help       Show this help

USAGE
}

find_app() {
  local candidate
  for candidate in "${APP_CANDIDATES[@]}"; do
    if [[ -n "$candidate" && -d "$candidate" ]]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done
  return 1
}

install_tokenbar() {
  /bin/bash -c "$(curl -fsSL "$install_url")"
}

supports_animation() {
  [[ -t 1 && "${TERM:-dumb}" != "dumb" && -z "${NO_COLOR:-}" ]]
}

plain_open_message() {
  printf 'Opened TokenBar: %s\n' "$1"
}

animated_open_message() {
  local app_path="$1"
  local cyan=$'\033[36m'
  local blue=$'\033[34m'
  local amber=$'\033[33m'
  local green=$'\033[32m'
  local violet=$'\033[35m'
  local dim=$'\033[2m'
  local reset=$'\033[0m'
  local clear=$'\033[2K'
  local frames=(
    "e-  e-  e-       ${amber}J${reset}/$  →  ${dim}waiting for context${reset}"
    " e-  ✧  e-      ${amber}J${reset}/$  →  ${cyan}token seed${reset}"
    "  ✧  [tok] ✧    ${amber}W${reset}/$  →  ${cyan}context sparks${reset}"
    " [tok] ⇄ [tok]  ${amber}tokens${reset}/${blue}watt${reset}/${green}dollar${reset}"
    "   ◜●◝  VS  100%  ${violet}quota gate${reset}"
    "  /▣\\  →  ${cyan}TokenBar opening menu-bar radar${reset}"
    " ✦ [TOKENS] ✦  ${green}visible${reset}  ${dim}limits forecast cost${reset}"
  )
  local frame

  trap "printf '\033[?25h'; trap - INT TERM EXIT" INT TERM EXIT
  printf '\033[?25l'
  for frame in "${frames[@]}"; do
    printf '\r%s%s' "$clear" "$frame"
    sleep 0.11
  done
  printf '\r%s%s✓ TokenBar is live%s  %stokens / watt / dollar%s\n' "$clear" "$green" "$reset" "$amber" "$reset"
  printf '%s%s%s\n' "$dim" "$app_path" "$reset"
  printf '\033[?25h'
  trap - INT TERM EXIT
}

quiet=false
animate=true

case "${1:-}" in
  -h|--help|help)
    usage
    exit 0
    ;;
  --install|install)
    install_tokenbar
    exit 0
    ;;
  --path|path)
    find_app
    exit $?
    ;;
  --quiet|-q)
    quiet=true
    animate=false
    ;;
  --no-animation|--plain)
    animate=false
    ;;
  "")
    ;;
  *)
    echo "Unknown option: $1" >&2
    usage >&2
    exit 2
    ;;
esac

if app_path="$(find_app)"; then
  open "$app_path"
  if [[ "$quiet" == true ]]; then
    exit 0
  elif [[ "$animate" == true ]] && supports_animation; then
    animated_open_message "$app_path"
  else
    plain_open_message "$app_path"
  fi
  exit 0
fi

cat >&2 <<EOF
TokenBar is not installed yet.

Install it with:
  curl -fsSL $install_url | bash

Or download it manually:
  $download_url
EOF
exit 1
